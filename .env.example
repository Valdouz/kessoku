# Kessoku — variables d'environnement (exemple).
# Copier en ".env" si besoin. NE JAMAIS commiter de vrai .env (déjà gitignoré).
#
# L'app est LOCAL-FIRST : aucune variable n'est requise pour un usage solo.
#
# COLLABORATIF (temps réel) — par défaut AUCUNE config requise :
# le client vise automatiquement le MÊME domaine, chemin /sync (ws en HTTP, wss en
# HTTPS), proxifié par nginx vers le serveur de synchro. Marche tel quel derrière
# un reverse proxy / tunnel Cloudflare (un seul port public).
#
# Ne définir VITE_SYNC_URL que si le backend est sur un hôte SÉPARÉ.
# Valeur figée AU BUILD (Vite).
# VITE_SYNC_URL=wss://sync.mon-domaine.fr

# ── BACKEND (auth + données) — lu par docker compose ─────────────────────────
# Copie ce fichier en ".env" (déjà gitignoré) et renseigne au moins ADMIN_PASSWORD.
#
# Compte administrateur créé au PREMIER démarrage (base vide) :
ADMIN_USERNAME=admin
# OBLIGATOIRE : choisis un mot de passe FORT et unique (remplace ce placeholder).
# Si tu le laisses vide, un mot de passe aléatoire fort est généré et affiché
# UNE FOIS dans les logs du conteneur (docker compose logs api) — note-le.
ADMIN_PASSWORD=__CHANGE_MOI__
#
# Secret de signature des sessions (JWT). Laisse vide => généré et persisté
# automatiquement dans le volume de données. Pour le fixer toi-même :
#   openssl rand -hex 48
# JWT_SECRET=
#
# Port interne du backend (rarement à changer).
# PORT=1234

# Jeton de service pour exposer GET /api/next-event (consommé par le bot Discord).
# Laisse vide => endpoint désactivé. Doit correspondre à SITE_API_TOKEN du bot.
#   openssl rand -hex 24
# SERVICE_TOKEN=

# « Se connecter avec Discord » (OAuth2). Laisse vide => fonctionnalité désactivée.
# Depuis https://discord.com/developers (ton application) :
#  - DISCORD_CLIENT_ID   = OAuth2 → Client ID (= l'ID de l'application)
#  - DISCORD_CLIENT_SECRET = OAuth2 → Client Secret (à régénérer/copier)
# Et dans OAuth2 → Redirects, ajoute EXACTEMENT :
#   https://kessoku.fallcityband.com/api/auth/discord/callback
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
