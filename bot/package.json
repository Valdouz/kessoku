{
  "name": "kessoku-bot",
  "private": true,
  "version": "0.1.0",
  "description": "Bot Discord Kessoku — multi-serveurs, handler de commandes, SQLite",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "node dist/deploy-commands.js",
    "deploy:dev": "tsx src/deploy-commands.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}