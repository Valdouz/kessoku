# Bot Discord Kessoku — copie en ".env" (déjà gitignoré). Aucun secret sur git.

# Jeton du bot (Portail développeur Discord → ton application → Bot → Reset Token)
DISCORD_TOKEN=

# Identifiant d'application. Laisse VIDE => dérivé automatiquement du token au déploiement.
DISCORD_CLIENT_ID=

# Guilde de test : déploiement INSTANTANÉ des slash commands sur ce serveur.
# Laisse vide pour des commandes GLOBALES (propagation ~1h).
DISCORD_GUILD_ID=

# Interaction future avec le site (API HTTP) — non requis pour l'autorole.
SITE_API_URL=https://kessoku.fallcityband.com
SITE_API_TOKEN=

# Dossier de la base SQLite du bot.
DATA_DIR=./data
